{
  "expo": {
    "name": "Horoscope",
    "slug": "horoscope-app",
    "scheme": "horoscope",
    "version": "1.0.0",
    "orientation": "portrait",
    "backgroundColor": "#070914",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-secure-store",
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "config": {
        "usesNonExemptEncryption": false
      }
    }
  }
}
